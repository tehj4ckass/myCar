carconnectivity/carconnectivity.json
carconnectivity/id3_data*.db

# ── Python cache ───────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# ── Scratch / temp ─────────────────────────────────────────────────────────────
dashboard/scratch/
*.log
