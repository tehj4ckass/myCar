# ── Credentials & secrets ──────────────────────────────────────────────────────
.env

# ── Database (personal vehicle data – keep local only) ─────────────────────────
database/*.db

# ── Mosquitto runtime state ────────────────────────────────────────────────────
mosquitto/data/
mosquitto/log/

